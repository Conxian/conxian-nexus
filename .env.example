# Conxian Nexus Configuration (Example)
# DO NOT COMMIT ACTUAL SECRETS

# Server Configuration
REST_PORT=3000
GRPC_PORT=50051
RUST_LOG=info

# Persistence
DATABASE_URL=postgres://user:pass@localhost:5432/nexus
REDIS_URL=redis://127.0.0.1:6379

# Stacks Network
STACKS_NODE_RPC_URL=https://api.mainnet.hiro.so

# Oracle Service
NEXUS_ORACLE_ENABLED=0
NEXUS_ORACLE_STUB_OK=1
ORACLE_ENDPOINT_URL=https://open.er-api.com/v6/latest/USD
ORACLE_CONTRACT_PRINCIPAL=SP...

# Experimental
NEXUS_EXPERIMENTAL_APIS=1

# Security (Set this in a local .env only)
# NEXUS_PRIVATE_KEY=your_private_key_hex
